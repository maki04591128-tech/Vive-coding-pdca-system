# =============================================================
# vibe-pdca LLM ゲートウェイ 環境変数
# =============================================================
# このファイルを .env にコピーして各プロバイダの API キーを設定してください
# cp .env.example .env

# ── 環境 ──
VIBE_PDCA_ENV=dev

# ── クラウドLLM APIキー ──
# OpenAI (PM: GPT-5.1)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (プログラマ: Claude Opus 4 / DO: Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google (書記: Gemini 3 Pro / デザイナ: Gemini 3.1 Pro)
GOOGLE_API_KEY=your-google-api-key-here

# xAI (ユーザ: Grok 4)
XAI_API_KEY=your-xai-api-key-here

# ── ローカルLLM ──
# Ollama のデフォルトURL (変更不要の場合はコメントアウト)
# OLLAMA_BASE_URL=http://localhost:11434/v1
