# =============================================================
# vibe-pdca LLM ゲートウェイ 環境変数
# =============================================================
# このファイルを .env にコピーして各プロバイダの API キーを設定してください
# cp .env.example .env

# ── 環境 ──
VIBE_PDCA_ENV=dev

# ── LLMモード切替 ──
# 優先モード: cloud（クラウドLLM優先）/ local（ローカルLLM優先）
# 環境変数が設定ファイル（config/default.yml の llm.preferred_mode）より優先されます
# VIBE_PDCA_LLM_MODE=local

# 自動フォールバック: true / false
# 無効にすると、優先モードのプロバイダ障害時に代替プロバイダへ切り替わりません
# VIBE_PDCA_LLM_AUTO_FALLBACK=true

# ── クラウドLLM APIキー ──
# OpenAI (PM: GPT-5.1)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (プログラマ: Claude Opus 4 / DO: Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google (書記: Gemini 3 Pro / デザイナ: Gemini 3.1 Pro)
GOOGLE_API_KEY=your-google-api-key-here

# xAI (ユーザ: Grok 4)
XAI_API_KEY=your-xai-api-key-here

# ── ローカルLLM ──
# Ollama のデフォルトURL (変更不要の場合はコメントアウト)
# OLLAMA_BASE_URL=http://localhost:11434/v1
