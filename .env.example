# =============================================================
# vibe-pdca LLM ゲートウェイ 環境変数
# =============================================================
# このファイルを .env にコピーして各プロバイダの API キーを設定してください
# cp .env.example .env

# ── 環境 ──
VIBE_PDCA_ENV=dev

# ── LLMモード切替 ──
# 優先モード: cloud（クラウドLLM優先）/ local（ローカルLLM優先）
# 環境変数が設定ファイル（config/default.yml の llm.preferred_mode）より優先されます
# VIBE_PDCA_LLM_MODE=local

# 自動フォールバック: true / false (false, 0, no で無効化)
# 無効にすると、優先モードのプロバイダ障害時に代替プロバイダへ切り替わりません
# VIBE_PDCA_LLM_AUTO_FALLBACK=true

# ── クラウドLLM APIキー ──
# OpenAI (PM: GPT-5.1)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (プログラマ: Claude Opus 4 / DO: Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google (書記: Gemini 3 Pro / デザイナ: Gemini 3.1 Pro)
GOOGLE_API_KEY=your-google-api-key-here

# xAI (ユーザ: Grok 4)
XAI_API_KEY=your-xai-api-key-here

# ── ローカルLLM ──
# Ollama のデフォルトURL (変更不要の場合はコメントアウト)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── ローカルLLMモデル切替 ──
# 環境変数でローカルLLMのモデルやURLを上書きできます（YAML設定の編集不要）
#
# ▼ 全プロバイダ一括上書き:
# VIBE_PDCA_LOCAL_LLM_MODEL=llama3.3:70b
#
# ▼ 役割別に個別指定（一括より優先）:
# VIBE_PDCA_LOCAL_LLM_MODEL_PM=qwen3:72b
# VIBE_PDCA_LOCAL_LLM_MODEL_SCRIBE=qwen3:72b
# VIBE_PDCA_LOCAL_LLM_MODEL_PROGRAMMER=codestral:22b
# VIBE_PDCA_LOCAL_LLM_MODEL_DESIGNER=llama3.3:70b
# VIBE_PDCA_LOCAL_LLM_MODEL_USER=gemma3:27b
# VIBE_PDCA_LOCAL_LLM_MODEL_DO=codestral:22b
#
# ▼ 🚀 高性能モデル構成（VRAM 48GB以上の環境向け）:
# VIBE_PDCA_LOCAL_LLM_MODEL_PM=deepseek-v3
# VIBE_PDCA_LOCAL_LLM_MODEL_SCRIBE=deepseek-v3
# VIBE_PDCA_LOCAL_LLM_MODEL_PROGRAMMER=devstral:24b
# VIBE_PDCA_LOCAL_LLM_MODEL_DESIGNER=kimi-k2.5
# VIBE_PDCA_LOCAL_LLM_MODEL_USER=qwen3:235b
# VIBE_PDCA_LOCAL_LLM_MODEL_DO=devstral:24b
#
# 優先順位: 役割別環境変数 > 一括環境変数 > config/default.yml

# vLLM / llama.cpp / LM Studio 等の別サーバーを使う場合:
# VIBE_PDCA_LOCAL_LLM_BASE_URL=http://localhost:8000/v1

# ── CI/CDサービス連携 ──
# GitHub Actions API トークン（ワークフロー実行結果の自動取得に使用）
# GITHUB_TOKEN=ghp_your-github-token-here

# GitLab CI API トークン（パイプライン結果の自動取得に使用）
# GITLAB_TOKEN=glpat-your-gitlab-token-here
